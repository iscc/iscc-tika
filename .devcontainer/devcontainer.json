{
  "name": "iscc-tika",
  "runArgs": ["--cpus=4", "--memory=16g", "--shm-size=1g"],
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:UTC}",
      "CLAUDE_CODE_VERSION": "latest"
    }
  },
  "initializeCommand": "bash .devcontainer/init-host.sh",
  "remoteUser": "dev",
  "mounts": [
    "source=${localEnv:USERPROFILE}/.claude,target=/home/dev/.claude,type=bind",
    "source=${localEnv:USERPROFILE}/.claude.json,target=/home/dev/.claude.json,type=bind",
    "source=${localEnv:USERPROFILE}/.codex,target=/home/dev/.codex,type=bind",
    "source=${localEnv:USERPROFILE}/.gitconfig,target=/home/dev/.gitconfig-host,type=bind,readonly",
    "source=iscc-tika-bashhistory,target=/commandhistory,type=volume",
    "source=iscc-tika-cargo-registry,target=/home/dev/.cargo/registry,type=volume",
    "source=iscc-tika-cargo-git,target=/home/dev/.cargo/git,type=volume",
    "source=iscc-tika-target,target=/workspace/iscc-tika/target,type=volume",
    "source=iscc-tika-uv-cache,target=/home/dev/.cache/uv,type=volume",
    "source=iscc-tika-venv,target=/home/dev/.venvs/iscc-tika,type=volume",
    "source=iscc-tika-gradle-cache,target=/home/dev/.gradle,type=volume",
    "source=iscc-tika-sccache,target=/home/dev/.cache/sccache,type=volume"
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "GH_TOKEN": "${localEnv:GH_TOKEN}",
    "UV_PROJECT_ENVIRONMENT": "/home/dev/.venvs/iscc-tika",
    "GIT_CONFIG_COUNT": "1",
    "GIT_CONFIG_KEY_0": "commit.gpgsign",
    "GIT_CONFIG_VALUE_0": "false",
    "RUSTC_WRAPPER": "sccache",
    "SCCACHE_DIR": "/home/dev/.cache/sccache",
    "CARGO_BUILD_JOBS": "4"
  },
  "postCreateCommand": "sudo chown -R dev:dev /home/dev/.venvs /home/dev/.cargo/registry /home/dev/.cargo/git /home/dev/.gradle /home/dev/.cache/sccache /workspace/iscc-tika/target && .devcontainer/setup-gitconfig.sh && .devcontainer/setup-codex.sh && .devcontainer/setup-dev.sh",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/iscc-tika,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace/iscc-tika"
}
